# GenCore Playground Environment
# Copy this file to .env and adjust values for your environment.

# -- App ---------------------------------------------
# GENCORE_ENV=development
# PORT=3000

# -- Playground Database -----------------------------
# Supported providers: libsql | postgres
GENCORE_PLAYGROUND_DATABASE_PROVIDER=libsql

# libSQL mode (default)
GENCORE_PLAYGROUND_LIBSQL_DB_PATH=./data/playground/playground.db

# PostgreSQL mode
# GENCORE_PLAYGROUND_POSTGRES_URL=postgresql://gencore:gencore@localhost:5434/gencore_playground

# Schema management: update | migrations | none
GENCORE_PLAYGROUND_SCHEMA_MODE=update

# -- Auth --------------------------------------------
GENCORE_AUTH_JWT_SECRET=change-me-use-a-long-random-secret
GENCORE_AUTH_ISSUER=gencore-playground-api
GENCORE_AUTH_AUDIENCE=gencore-playground

# -- Seed --------------------------------------------
GENCORE_PLAYGROUND_SEED_ENABLED=true

# Roles format: name:description;name:description
GENCORE_PLAYGROUND_SEED_ROLES=admin:Full system access and management.;member:Standard authenticated user.

# Admin user seed
GENCORE_PLAYGROUND_SEED_ADMIN_ENABLED=true
GENCORE_PLAYGROUND_SEED_ADMIN_EMAIL=admin@admin.com
GENCORE_PLAYGROUND_SEED_ADMIN_PASSWORD=@Dmin123!
GENCORE_PLAYGROUND_SEED_ADMIN_DISPLAY_NAME=Admin
GENCORE_PLAYGROUND_SEED_ADMIN_ROLES=admin
GENCORE_PLAYGROUND_SEED_ADMIN_OVERWRITE_PASSWORD=false

# -- Storage -----------------------------------------
# Supported providers: local | s3
GENCORE_PLAYGROUND_STORAGE_PROVIDER=local

# Local mode
GENCORE_PLAYGROUND_STORAGE_LOCAL_ROOT=./data/storage
# GENCORE_PLAYGROUND_STORAGE_PUBLIC_BASE_URL=http://localhost:3000/public/storage

# S3 / MinIO mode
# GENCORE_PLAYGROUND_STORAGE_S3_ENDPOINT=http://localhost:9000
# GENCORE_PLAYGROUND_STORAGE_S3_REGION=us-east-1
# GENCORE_PLAYGROUND_STORAGE_S3_ACCESS_KEY_ID=gencore
# GENCORE_PLAYGROUND_STORAGE_S3_SECRET_ACCESS_KEY=gencore-secret
# GENCORE_PLAYGROUND_STORAGE_S3_FORCE_PATH_STYLE=true
# GENCORE_PLAYGROUND_STORAGE_S3_DEFAULT_BUCKET=playground
# GENCORE_PLAYGROUND_STORAGE_S3_PUBLIC_BASE_URL=http://localhost:9000/playground
