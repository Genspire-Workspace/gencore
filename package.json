{
  "name": "gencore",
  "version": "0.0.0",
  "private": true,
  "description": "Bun-first TypeScript framework for AI-native APIs, CLIs, agents, and workspace backends.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test --path-ignore-patterns '**/old_spirecorejs/**' --pass-with-no-tests",
    "generate:models": "bun run packages/ai/scripts/generate-models.ts",
    "dev": "bun run apps/playground-api/src/index.ts",
    "dev:playground-api": "bun run apps/playground-api/src/index.ts",
    "dev:person-api": "bun run apps/person-api/src/index.ts",
    "db:playground:create": "bun run apps/playground-api/src/database/playground-migrations.ts create",
    "db:playground:up": "bun run apps/playground-api/src/database/playground-migrations.ts up",
    "db:playground:down": "bun run apps/playground-api/src/database/playground-migrations.ts down",
    "db:playground:pending": "bun run apps/playground-api/src/database/playground-migrations.ts pending",
    "db:playground:executed": "bun run apps/playground-api/src/database/playground-migrations.ts executed",
    "clean": "rm -rf node_modules bun.lock packages/*/dist apps/*/dist",
    "sync:file-paths": "bun scripts/sync-file-path-relative.mjs",
    "env:list": "bun run scripts/manage-env.mjs list",
    "env:sync": "bun run scripts/manage-env.mjs sync",
    "env:use": "bun run scripts/manage-env.mjs use",
    "env:local": "bun run scripts/manage-env.mjs use local",
    "env:docker": "bun run scripts/manage-env.mjs use docker",
    "env:example": "bun run scripts/manage-env.mjs use example",
    "dev:ai:verify": "bun run apps/playground-test/ai/verify-generation.ts",
    "dev:ai-context:verify": "bun run apps/playground-test/ai/verify-ai-context.ts",
    "dev:api:verify": "bun run apps/playground-test/ai/verify-api.ts",
    "dev:ai:verify:local": "bun run dev:ai:verify && bun run dev:ai-context:verify"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "reflect-metadata": "^0.2.2",
    "tinyglobby": "^0.2.13",
    "typescript": "latest"
  },
  "dependencies": {}
}
