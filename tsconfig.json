{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",

    // Bun / bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Migration-friendly strictness
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    // Bun types
    "types": ["bun"],

    // Workspace aliases - no baseUrl needed in TS 6+
    "paths": {
      "@genspire/core": ["./packages/core/src/index.ts"],
      "@genspire/server": ["./packages/server/src/index.ts"],
      "@genspire/data": ["./packages/data/src/index.ts"],
      "@genspire/data-mikroorm": ["./packages/data-mikroorm/src/index.ts"],
      "@genspire/swagger": ["./packages/swagger/src/index.ts"],
      "@genspire/auth": ["./packages/auth/src/index.ts"],
      "@genspire/auth/domain": ["./packages/auth/src/domain.ts"],
      "@genspire/auth/application": ["./packages/auth/src/application.ts"],
      "@genspire/auth/infrastructure": ["./packages/auth/src/infrastructure.ts"],
      "@genspire/auth/server": ["./packages/auth/src/server.ts"],
      "@genspire/storage": ["./packages/storage/src/index.ts"],
      "@genspire/storage/domain": ["./packages/storage/src/domain.ts"],
      "@genspire/storage/application": ["./packages/storage/src/application.ts"],
      "@genspire/storage/infrastructure": ["./packages/storage/src/infrastructure.ts"],
      "@genspire/storage/server": ["./packages/storage/src/server.ts"],
      "@genspire/ai": ["./packages/ai/src/index.ts"],
      "@genspire/ai/domain": ["./packages/ai/src/domain.ts"],
      "@genspire/ai/application": ["./packages/ai/src/application.ts"],
      "@genspire/ai/providers": ["./packages/ai/src/providers.ts"],
      "@genspire/ai/server": ["./packages/ai/src/server.ts"],
      "@genspire/ai/server/contracts": ["./packages/ai/src/server/contracts.ts"],
      "@genspire/ai/extension": ["./packages/ai/src/extension/index.ts"],
      "@genspire/ai/infrastructure": ["./packages/ai/src/infrastructure.ts"],
      "@genspire/ai/catalogue": ["./packages/ai/src/catalogue.ts"],
      "@genspire/ai/providers/ollama": ["./packages/ai/src/providers/ollama/index.ts"],
      "@genspire/ai/providers/openai-compatible": ["./packages/ai/src/providers/openai-compatible/index.ts"],
      "@mikro-orm/decorators": ["./apps/playground-api/node_modules/@mikro-orm/decorators/es/index.d.ts"],
      "@mikro-orm/decorators/es": ["./apps/playground-api/node_modules/@mikro-orm/decorators/es/index.d.ts"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "apps/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "old_spirecorejs"
  ]
}
